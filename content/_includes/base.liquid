<!doctype html>
<html lang="ja" class="wa-theme-default wa-cloak">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <meta name="color-scheme" content="light dark">
    <script>
      (function () {
        const root = document.documentElement;
        const mq = window.matchMedia && matchMedia('(prefers-color-scheme: dark)');
        function sync() {
          root.classList.toggle('wa-dark', Boolean(mq && mq.matches));
        }
        sync();
        if (mq && mq.addEventListener) {
          mq.addEventListener('change', sync);
        }
      })();
    </script>
    <title>
      {%- if title -%}
        {{- title }} · otariidae.com
      {%- else -%}
        otariidae.com
      {%- endif -%}
    </title>
    <link rel="stylesheet" href="/vendor/webawesome/styles/webawesome.css">
    <style>
      body {
        min-height: 100vh;
        display: flex;
        flex-direction: column;
        background-color: var(--wa-color-surface-default);
        color: var(--wa-color-text-normal);
      }

      body > main {
        flex: 1;
      }

      .container {
        width: 100%;
        max-width: 1024px;
        margin-inline: auto;
        padding-inline: var(--wa-space-m);
        box-sizing: border-box;
      }

      .site-nav {
        padding-block: var(--wa-space-m);
      }

      .site-footer {
        padding-block: calc(var(--wa-space-m) * 1.25);
        color: var(--wa-color-text-quiet);
      }

      .site-footer p {
        margin-bottom: 0;
      }

      .post-index {
        list-style: none;
        padding: 0;
        margin: 0;
      }

      .post-index > li {
        margin: 0;
        list-style: none;
      }

      .post-index-divider {
        --spacing: var(--wa-space-3xs);
      }

      .post-index-link {
        padding-block: var(--wa-space-xs);
        text-decoration: none;
        color: inherit;
        box-shadow: none;
        --flank-size: 12rem;
      }

      .post-index-link:hover,
      .post-index-link:focus,
      .post-index-link:active {
        text-decoration: none;
      }

      .post-index-link:focus-visible {
        outline: 2px solid var(--wa-color-focus);
        outline-offset: 2px;
        border-radius: var(--wa-border-radius-s);
        box-shadow: none;
      }

      .post-index-date {
        font-size: var(--wa-font-size-s);
        color: var(--wa-color-text-quiet);
        font-variant-numeric: tabular-nums;
        white-space: nowrap;
        text-align: end;
        text-decoration: none;
      }

      .post-index-main {
        min-width: 0;
      }

      .post-index-title {
        margin: 0;
        min-width: 0;
        font-weight: var(--wa-font-weight-semibold);
        line-height: var(--wa-line-height-normal);
        color: var(--wa-color-text-link);
        text-decoration: none;
      }

      .post-index-link:hover .post-index-title {
        text-decoration: underline;
        text-underline-offset: 0.15em;
      }

      .post-index-external-tag wa-icon {
        font-size: 0.75em;
        vertical-align: -0.1em;
      }

      @media (max-width: 32rem) {
        .post-index-link {
          --flank-size: auto;
          padding-block: var(--wa-space-s);
        }

        .post-index-date {
          white-space: normal;
          text-align: start;
        }
      }

      .home-profile-heading {
        margin: 0;
        font-size: clamp(1.35rem, 4vw, 1.75rem);
        line-height: var(--wa-line-height-normal);
      }

      .home-profile-body {
        min-width: 0;
      }

      .home-profile-links {
        list-style: none;
        margin: 0;
        padding: 0;
      }

      .home-profile-links li {
        margin: 0;
      }

      @media (max-width: 32rem) {
        .home-profile {
          text-align: center;
        }

        .home-profile .wa-flank {
          justify-content: center;
        }

        .home-profile-body {
          align-items: center;
        }

        .home-profile-links {
          justify-content: center;
        }
      }

      /* 記事: longform の明朝トークンをゴシック（本文）に揃え、行間をやや広げる */
      article {
        --wa-font-family-longform: var(--wa-font-family-body);
      }

      article .wa-longform {
        line-height: 1.75;
      }

      /*
        日本語記事: CSS Text 4 系（対応ブラウザのみ）
        - text-autospace: 漢字かなと欧文・数字のあいだを自動アキ
        - text-spacing-trim: 約物まわりの余白調整（フォントが halt/chws に対応している場合）
        - line-break: strict: 和文の禁則に寄せた改行
      */
      article:lang(ja) {
        text-autospace: normal;
        text-spacing-trim: normal;
        line-break: strict;
      }

      article:lang(ja) pre {
        text-autospace: no-autospace;
        text-spacing-trim: space-all;
      }
    </style>
  </head>
  <body>
    <header class="site-header">
      <nav class="container site-nav" aria-label="サイト全体">
        <div class="wa-cluster wa-gap-m">
          <a href="/"><strong>otariidae.com</strong></a>
        </div>
      </nav>
      <wa-divider></wa-divider>
    </header>
    <main id="main-content" class="container wa-stack wa-gap-2xl">{{ content | raw }}</main>
    <footer class="site-footer">
      <wa-divider style="--spacing: var(--wa-space-m);"></wa-divider>
      <div class="container">
        <p>
          <small>
            © {% if buildYear %}{{ buildYear }}{% else %}2026{% endif %}
            otariidae.
            <a href="https://creativecommons.org/licenses/by/4.0/deed.ja" rel="license">CC BY 4.0</a>
          </small>
        </p>
      </div>
    </footer>
    <script type="module" src="/vendor/webawesome/webawesome.loader.js"></script>
  </body>
</html>
