---
layout: base.liquid
fontawesome: true
---
<section class="home-profile" aria-labelledby="profile-heading">
  {% comment %} Avatar: GitHub https://avatars.githubusercontent.com/u/20238714 を保存 {% endcomment %}
  <img
    class="home-profile-avatar"
    src="/img/avatar.jpg"
    alt=""
    width="460"
    height="460"
    decoding="async"
  />
  <div class="home-profile-body">
    <h1 id="profile-heading">otariidae</h1>
    <ul class="home-profile-links">
      <li><a href="https://github.com/otariidae" rel="me noopener noreferrer">github.com/otariidae</a></li>
    </ul>
  </div>
</section>

<section id="posts" aria-labelledby="posts-heading">
  <h2 id="posts-heading">ブログ</h2>
  <ul class="post-index" role="list">
    {%- for post in collections.posts -%}
      <li>
        <a
          href="{{ post.url }}"
          class="post-index-link"
          {% if post.external -%}
            rel="noopener noreferrer"
          {%- endif %}
        >
          <time datetime="{{ post.data.published | yyyyMmDd }}" class="post-index-date">{{ post.data.published | dateJa }}</time>
          <span class="post-index-main">
            <span class="post-index-title-row">
              <h3 class="post-index-title">{{ post.data.title }}</h3>
              {% if post.external %}
                <span class="post-index-source-badge">
                  <i class="fa-solid fa-up-right-from-square post-index-source-icon" aria-hidden="true"></i>
                  <span class="post-index-source-label">{{ post.publication | default: "外部サイト" }}</span>
                </span>
              {% endif %}
            </span>
            {% if post.publication %}
              {% unless post.external %}
                <span class="post-index-publication">{{ post.publication }}</span>
              {% endunless %}
            {% endif %}
          </span>
        </a>
      </li>
    {%- endfor -%}
  </ul>
</section>
